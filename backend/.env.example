# ---------------------------------------------------------------------
# .env.example
# Copy this file to ".env" and fill in values ONLY when you wire up a
# real LLM provider in solver.py. The app runs perfectly fine with no
# .env file at all, since MockSolver requires no API keys.
# ---------------------------------------------------------------------

# TODO: Uncomment and set when integrating Gemini
# GEMINI_API_KEY=

# TODO: Uncomment and set when integrating OpenAI
# OPENAI_API_KEY=

# TODO: Uncomment and set when integrating Claude (Anthropic)
# ANTHROPIC_API_KEY=

# TODO: Uncomment and set when integrating Ollama (local LLM server)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# TODO: Uncomment and set when integrating a generic REST API provider
# SOLVER_API_URL=
# SOLVER_API_KEY=
